*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
-A POSTROUTING -o {{ wan_interface }} -j MASQUERADE
COMMIT

*filter
:INPUT ACCEPT [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
-A FORWARD -i {{ wan_interface }} -o {{ bat_interface }} -m state --state RELATED,ESTABLISHED -j ACCEPT
-A FORWARD -i {{ bat_interface }} -o {{ wan_interface }} -j ACCEPT
COMMIT
