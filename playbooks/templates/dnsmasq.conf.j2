interface={{bat_interface}}
interface=lo
bind-interfaces
domain-needed
bogus-priv
dhcp-range={{dhcp_start}},{{dhcp_end}},{{lease_time}}h
dhcp-option=option:router,{{ manager_mesh_ip }}
dhcp-option=option:dns-server,{{ manager_mesh_ip }}
resolv-file=/run/systemd/resolve/resolv.conf
dhcp-option=option:domain-search,gotham
domain=gotham
local=/gotham/

# Workers get <name>.gotham free from their DHCP lease hostname. Manager
# doesn't lease from its own dnsmasq (bat0 static), so it needs this explicit
# record - expand-hosts would instead synthesize one from /etc/hosts's
# "127.0.1.1" self-entry, pointing manager0.gotham at loopback and breaking
# every worker's k3s join.
host-record={{ pi_hostname }}.gotham,{{ pi_hostname }},{{ manager_mesh_ip }}

# dashboard.gotham (dashboard/homepage.yml NodePort) - any node's IP reaches
# any NodePort, same as registry_host does for Zot.
host-record=dashboard.gotham,dashboard,{{ manager_mesh_ip }}