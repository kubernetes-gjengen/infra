interface={{bat_interface}}
bind-interfaces
domain-needed
bogus-priv
dhcp-range={{dhcp_start}},{{dhcp_end}},{{lease_time}}h
dhcp-option=option:router,{{ manager_mesh_ip }}
dhcp-option=option:dns-server,{{ manager_mesh_ip }}
resolv-file=/run/systemd/resolve/resolv.conf
dhcp-option=option:domain-search,gotham
domain=gotham
local=/gotham/
expand-hosts